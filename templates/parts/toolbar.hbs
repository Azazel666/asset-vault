<div class="av-toolbar-row av-breadcrumb-row">
  <button type="button" class="av-sidebar-toggle" data-action="toggleSidebar"
    title="{{localize 'asset-vault.nav.toggleSidebar'}}">
    <i class="fa-solid fa-bars"></i>
  </button>
  {{#unless isSearchMode}}
  <button type="button" class="av-back-btn" data-action="backTraverse"
    title="{{localize 'asset-vault.nav.back'}}">
    <i class="fa-solid fa-arrow-left"></i>
  </button>
  <nav class="av-breadcrumb">
    {{#each breadcrumbs}}
    {{#if isLast}}
    <span class="av-crumb av-crumb-current">{{label}}</span>
    {{else}}
    <button type="button" class="av-crumb av-crumb-btn" data-action="pickDirectory" data-path="{{path}}">{{label}}</button>
    <span class="av-crumb-sep">/</span>
    {{/if}}
    {{/each}}
  </nav>
  {{else}}
  <span class="av-search-result-count">{{searchResultText}}</span>
  {{/unless}}
</div>
<div class="av-toolbar-row av-search-row">
  <div class="av-search">
    <i class="fa-solid fa-magnifying-glass"></i>
    {{#each searchFilters}}
    <span class="av-search-chip" data-key="{{key}}" data-value="{{value}}">
      <span class="av-search-chip-label">{{key}}: {{value}}</span>
      <button type="button" class="av-search-chip-remove"
        data-action="removeSearchFilter" data-key="{{key}}" data-value="{{value}}">×</button>
    </span>
    {{/each}}
    <input type="search" class="av-search-input"
      placeholder="{{localize 'asset-vault.search.placeholder'}}" />
    <button type="button" class="av-search-clear" title="{{localize 'asset-vault.search.clear'}}">
      <i class="fa-solid fa-xmark"></i>
    </button>
  </div>
  <div class="av-view-controls">
    <button type="button" class="av-view-btn{{#if isGrid}} active{{/if}}"
      data-action="setViewMode" data-mode="grid"
      title="{{localize 'asset-vault.settings.viewMode.grid'}}">
      <i class="fa-solid fa-grip"></i>
    </button>
    <button type="button" class="av-view-btn{{#if isList}} active{{/if}}"
      data-action="setViewMode" data-mode="list"
      title="{{localize 'asset-vault.settings.viewMode.list'}}">
      <i class="fa-solid fa-list"></i>
    </button>
    <button type="button" class="av-view-btn av-search-hint-btn"
      title="{{localize 'asset-vault.search.hintTitle'}}">
      <i class="fa-solid fa-circle-question"></i>
    </button>
    {{#if canUpload}}
    <button type="button" class="av-view-btn av-upload-btn" data-action="uploadFile"
      title="{{localize 'asset-vault.toolbar.upload'}}">
      <i class="fa-solid fa-upload"></i>
    </button>
    {{/if}}
    <button type="button" class="av-view-btn av-detach-btn" data-action="detachWindow"
      title="{{#if isDetached}}{{localize 'asset-vault.toolbar.attach'}}{{else}}{{localize 'asset-vault.toolbar.detach'}}{{/if}}">
      <i class="fa-solid {{#if isDetached}}fa-down-left-and-up-right-to-center{{else}}fa-up-right-from-square{{/if}}"></i>
    </button>
  </div>
</div>
<div class="av-search-hint" hidden>
  {{localize "asset-vault.search.hint"}}
</div>
{{#if canUpload}}
<input type="file" class="av-upload-input" multiple hidden>
{{/if}}
